{
  "name": "@gustavoj/hilux",
  "version": "2.0.3",
  "description": "A bot detector for APIs, that analyzes HTTP requests",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hilux-dash": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./fastify": {
      "types": "./dist/plugins/fastify.d.ts",
      "require": "./dist/plugins/fastify.js"
    },
    "./express": {
      "types": "./dist/plugins/express.d.ts",
      "require": "./dist/plugins/express.js"
    }
  },
  "files": [
    "dist",
    "dashboard-ui/out",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bot-detection",
    "api-security",
    "rate-limiting",
    "waf",
    "middleware",
    "fastify",
    "express",
    "risk-score",
    "ip-reputation",
    "security"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.0.1",
    "geoip-lite": "^2.0.1",
    "ioredis": "^5.4.2",
    "ioredis-mock": "^8.13.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
